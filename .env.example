# ============================================================
# Base de datos (Prisma)
# - Desarrollo: SQLite local
# - Producción: Cambiar provider a "postgresql" en prisma/schema.prisma
#   y usar URL de Supabase/Neon/Vercel Postgres
# ============================================================

DATABASE_URL=file:./db/custom.db

# ============================================================
# Mercado Pago — Credenciales de producción
# Solicitar desde: https://www.mercadopago.com/developers/panel
# El prefijo APP_USR- es normal tanto en sandbox como producción.
# Lo que determina si es real o test es el MODO de la aplicación
# en el dashboard de MP (Producción vs Test/Sandbox).
# ============================================================

MERCADOPAGO_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# PayPal — Correo que recibe los pagos internacionales
# ============================================================

PAYPAL_EMAIL=rrojase@unac.edu.pe

# ============================================================
# URL base del sitio (para back_urls de redirección)
# ============================================================

NEXT_PUBLIC_SITE_URL=https://www.academiaelprofeoficial.com

# ============================================================
# Firebase (mover desde hardcode a variables de entorno)
# ============================================================

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAeMHlQZtUwZqbH5o7nsb4eoUYXLM2y0PU
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=academia-el-profe.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=academia-el-profe
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=academia-el-profe.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=503462172387
NEXT_PUBLIC_FIREBASE_APP_ID=1:503462172387:web:3eed47f5763c396a1cd7d6

# ============================================================
# Administración
# UIDs de Firebase que tienen acceso admin (separados por coma)
# Obtén el UID del profe desde Firebase Console > Authentication > Users
# ============================================================

ADMIN_UIDS=

# ============================================================
# Email (opcional — para notificaciones)
# Regístrate en https://resend.com y pon tu API key aquí
# ============================================================

# RESEND_API_KEY=re_xxxxxxxxxxxx